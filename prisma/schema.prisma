generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  adventureModules   AdventureModule[]
  campaigns          Campaign[]
  characterTemplates CharacterTemplate[]
}

model AdventureModule {
  id                   String      @id @default(cuid())
  userId               String
  title                String
  premise              String
  tone                 String
  setting              String
  generationMode       String      @default("open_world")
  schemaVersion        Int         @default(1)
  isLocked             Boolean     @default(false)
  openWorldTemplateJson Json
  openWorldGenerationArtifactsJson Json?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns            Campaign[]
}

model CharacterTemplate {
  id           String              @id @default(cuid())
  userId       String
  name         String
  archetype    String
  strength     Int
  dexterity    Int
  constitution Int
  intelligence Int
  wisdom       Int
  charisma     Int
  maxHealth    Int
  backstory    String?
  starterItems String[]            @default([])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]
  instances    CharacterInstance[]
}

model Campaign {
  id                  String             @id @default(cuid())
  userId              String
  moduleId            String
  templateId          String
  moduleSchemaVersion Int                @default(1)
  selectedEntryPointId String
  turnLockRequestId   String?
  turnLockSessionId   String?
  turnLockExpiresAt   DateTime?
  stateVersion        Int                @default(0)
  generatedThroughDay Int                @default(0)
  infrastructureFailureCode String?
  degradedAt          DateTime?
  stateJson           Json
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  module              AdventureModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  template            CharacterTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  characterInstance   CharacterInstance?
  sessions            Session[]
  turns               Turn[]
  itemTemplates       ItemTemplate[]
  memories            MemoryEntry[]
  locationNodes       LocationNode[]
  locationEdges       LocationEdge[]
  factions            Faction[]
  factionRelations    FactionRelation[]
  npcs                NPC[]
  information         Information[]
  informationLinks    InformationLink[]
  commodities         Commodity[]
  marketPrices        MarketPrice[]
  npcRoutines         NpcRoutine[]
  factionMoves        FactionMove[]
  worldEvents         WorldEvent[]
  temporaryActors     TemporaryActor[]
  npcKnowledge        NpcKnowledge[]
  factionKnowledge    FactionKnowledge[]
  locationKnowledge   LocationKnowledge[]
  scheduleGenerationJobs ScheduleGenerationJob[]
  memoryEntityLinks   MemoryEntityLink[]
}

model CharacterInstance {
  id         String            @id @default(cuid())
  campaignId String            @unique
  templateId String
  health     Int
  gold       Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  template   CharacterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  inventory  ItemInstance[]
  commodityStacks CharacterCommodityStack[]
}

model CharacterCommodityStack {
  id                  String            @id @default(cuid())
  characterInstanceId String
  commodityId         String
  quantity            Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  characterInstance   CharacterInstance @relation(fields: [characterInstanceId], references: [id], onDelete: Cascade)
  commodity           Commodity         @relation(fields: [commodityId], references: [id], onDelete: Cascade)

  @@unique([characterInstanceId, commodityId])
  @@index([characterInstanceId])
  @@index([commodityId])
}

model ItemTemplate {
  id            String         @id @default(cuid())
  campaignId    String
  name          String
  description   String?
  value         Int            @default(0)
  weight        Float          @default(0)
  rarity        String         @default("common")
  tags          String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  itemInstances ItemInstance[]

  @@index([campaignId])
}

model ItemInstance {
  id                  String            @id @default(cuid())
  characterInstanceId String
  templateId          String
  isIdentified        Boolean           @default(true)
  charges             Int?
  properties          Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  characterInstance   CharacterInstance @relation(fields: [characterInstanceId], references: [id], onDelete: Cascade)
  template            ItemTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([characterInstanceId])
  @@index([templateId])
}

model Session {
  id            String        @id @default(cuid())
  campaignId    String
  title         String
  status        String
  turnCount     Int           @default(0)
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  summary       String?
  campaign      Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  messages      Message[]
  turns         Turn[]
  memoryEntries MemoryEntry[]
}

model Turn {
  id         String   @id @default(cuid())
  campaignId String
  sessionId  String
  requestId  String   @default(cuid())
  requestHash String  @default("")
  playerAction String
  status     String
  toolCallJson Json?
  resultJson Json?
  stateVersionAfter Int?
  infrastructureFailureCode String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  memoryEntries MemoryEntry[]
  scheduledJobs ScheduleGenerationJob[]

  @@index([campaignId, createdAt])
  @@index([campaignId, stateVersionAfter])
  @@unique([campaignId, requestId])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  kind      String
  content   String
  payload   Json?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model MemoryEntry {
  id         String   @id @default(cuid())
  campaignId String
  sessionId  String?
  turnId     String?
  type       String
  memoryKind String   @default("world_change")
  isLongArcCandidate Boolean @default(false)
  summary    String
  summarySource String @default("model")
  narrativeNote String?
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session    Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  turn       Turn?    @relation(fields: [turnId], references: [id], onDelete: SetNull)
  entityLinks MemoryEntityLink[]

  @@index([campaignId, createdAt])
}

model LocationNode {
  id                   String          @id
  campaignId           String
  name                 String
  type                 String
  summary              String
  description          String?
  localTextureJson     Json?
  state                String          @default("active")
  controllingFactionId String?
  tags                 String[]        @default([])
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  campaign             Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  controllingFaction   Faction?        @relation("ControlledLocationFaction", fields: [controllingFactionId], references: [id], onDelete: SetNull)
  edgesFrom            LocationEdge[]  @relation("EdgeSource")
  edgesTo              LocationEdge[]  @relation("EdgeTarget")
  npcs                 NPC[]
  information          Information[]
  knowledge            LocationKnowledge[]
  marketPrices         MarketPrice[]
  worldEvents          WorldEvent[]
  npcRoutineTargets    NpcRoutine[]    @relation("NpcRoutineTarget")
  temporaryActors      TemporaryActor[]

  @@index([campaignId])
  @@index([campaignId, controllingFactionId])
}

model LocationEdge {
  id                String       @id
  campaignId        String
  sourceId          String
  targetId          String
  travelTimeMinutes Int
  dangerLevel       Int          @default(1)
  currentStatus     String       @default("open")
  description       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  campaign          Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  source            LocationNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target            LocationNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([campaignId, sourceId])
  @@index([campaignId, targetId])
}

model Faction {
  id                 String            @id
  campaignId         String
  name               String
  type               String
  summary            String
  agenda             String
  resources          Json
  pressureClock      Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  campaign           Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  controlledLocations LocationNode[]   @relation("ControlledLocationFaction")
  npcs               NPC[]
  information        Information[]
  commodityPrices    MarketPrice[]
  factionMoves       FactionMove[]
  relationsFrom      FactionRelation[] @relation("FactionRelationSource")
  relationsTo        FactionRelation[] @relation("FactionRelationTarget")
  knowledge          FactionKnowledge[]

  @@index([campaignId])
}

model FactionRelation {
  id         String   @id
  campaignId String
  factionAId String
  factionBId String
  stance     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  factionA   Faction  @relation("FactionRelationSource", fields: [factionAId], references: [id], onDelete: Cascade)
  factionB   Faction  @relation("FactionRelationTarget", fields: [factionBId], references: [id], onDelete: Cascade)

  @@unique([campaignId, factionAId, factionBId])
  @@index([campaignId])
}

model NPC {
  id                String       @id
  campaignId        String
  name              String
  role              String
  summary           String
  description       String
  socialLayer       String       @default("anchor")
  isNarrativelyHydrated Boolean  @default(true)
  hydrationClaimRequestId String?
  hydrationClaimExpiresAt DateTime?
  factionId         String?
  currentLocationId String?
  approval          Int          @default(0)
  isCompanion       Boolean      @default(false)
  state             String       @default("active")
  threatLevel       Int          @default(1)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  campaign          Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  faction           Faction?     @relation(fields: [factionId], references: [id], onDelete: SetNull)
  currentLocation   LocationNode? @relation(fields: [currentLocationId], references: [id], onDelete: SetNull)
  information       Information[] @relation("InformationSourceNpc")
  marketPrices      MarketPrice[] @relation("VendorNpc")
  npcRoutines       NpcRoutine[]
  promotedTemporaryActors TemporaryActor[]
  knowledge         NpcKnowledge[]

  @@index([campaignId])
  @@index([campaignId, currentLocationId])
}

model Information {
  id               String            @id
  campaignId       String
  title            String
  summary          String
  content          String
  truthfulness     String            @default("true")
  accessibility    String            @default("public")
  locationId       String?
  factionId        String?
  sourceNpcId      String?
  isDiscovered     Boolean           @default(false)
  discoveredAtTurn Int?
  expiresAtTime    Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location         LocationNode?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  faction          Faction?          @relation(fields: [factionId], references: [id], onDelete: SetNull)
  sourceNpc        NPC?              @relation("InformationSourceNpc", fields: [sourceNpcId], references: [id], onDelete: SetNull)
  sourceLinks      InformationLink[] @relation("InformationLinkSource")
  targetLinks      InformationLink[] @relation("InformationLinkTarget")
  npcKnowledge     NpcKnowledge[]
  factionKnowledge FactionKnowledge[]
  locationKnowledge LocationKnowledge[]

  @@index([campaignId])
  @@index([campaignId, locationId, isDiscovered])
  @@index([campaignId, expiresAtTime])
}

model NpcKnowledge {
  id            String      @id @default(cuid())
  campaignId    String
  npcId         String
  informationId String
  shareability  String      @default("private")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  npc           NPC         @relation(fields: [npcId], references: [id], onDelete: Cascade)
  information   Information @relation(fields: [informationId], references: [id], onDelete: Cascade)

  @@unique([campaignId, npcId, informationId])
  @@index([campaignId, npcId])
  @@index([campaignId, informationId])
}

model FactionKnowledge {
  id            String      @id @default(cuid())
  campaignId    String
  factionId     String
  informationId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  faction       Faction     @relation(fields: [factionId], references: [id], onDelete: Cascade)
  information   Information @relation(fields: [informationId], references: [id], onDelete: Cascade)

  @@unique([campaignId, factionId, informationId])
  @@index([campaignId, factionId])
  @@index([campaignId, informationId])
}

model LocationKnowledge {
  id            String       @id @default(cuid())
  campaignId    String
  locationId    String
  informationId String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  campaign      Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location      LocationNode @relation(fields: [locationId], references: [id], onDelete: Cascade)
  information   Information  @relation(fields: [informationId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locationId, informationId])
  @@index([campaignId, locationId])
  @@index([campaignId, informationId])
}

model InformationLink {
  id         String      @id
  campaignId String
  sourceId   String
  targetId   String
  linkType   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  source     Information @relation("InformationLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target     Information @relation("InformationLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sourceId, targetId])
  @@index([campaignId])
}

model Commodity {
  id         String        @id
  campaignId String
  name       String
  baseValue  Int
  tags       String[]      @default([])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  marketPrices MarketPrice[]
  commodityStacks CharacterCommodityStack[]

  @@index([campaignId])
}

model MarketPrice {
  id          String       @id
  campaignId  String
  commodityId String
  locationId  String
  vendorNpcId String?
  factionId   String?
  modifier    Float        @default(1.0)
  stock       Int          @default(-1)
  restockTime Int?
  legalStatus String       @default("legal")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  commodity   Commodity    @relation(fields: [commodityId], references: [id], onDelete: Cascade)
  location    LocationNode @relation(fields: [locationId], references: [id], onDelete: Cascade)
  vendorNpc   NPC?         @relation("VendorNpc", fields: [vendorNpcId], references: [id], onDelete: SetNull)
  faction     Faction?     @relation(fields: [factionId], references: [id], onDelete: SetNull)

  @@unique([campaignId, commodityId, locationId, vendorNpcId])
  @@index([campaignId, locationId])
  @@index([campaignId, restockTime])
}

model NpcRoutine {
  id                 String       @id
  campaignId         String
  npcId              String
  triggerTimeMinutes Int
  triggerCondition   Json?
  targetLocationId   String
  activity           String
  priority           Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  campaign           Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  npc                NPC          @relation(fields: [npcId], references: [id], onDelete: Cascade)
  targetLocation     LocationNode @relation("NpcRoutineTarget", fields: [targetLocationId], references: [id], onDelete: Cascade)

  @@index([campaignId, npcId])
  @@index([campaignId, triggerTimeMinutes])
}

model FactionMove {
  id              String   @id
  campaignId      String
  factionId       String
  scheduledAtTime Int
  description     String
  payload         Json
  isExecuted      Boolean  @default(false)
  isCancelled     Boolean  @default(false)
  cancellationReason String?
  cascadeDepth    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  faction         Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)

  @@index([campaignId, scheduledAtTime, isExecuted, isCancelled])
}

model WorldEvent {
  id            String       @id
  campaignId    String
  locationId    String?
  triggerTime   Int
  triggerCondition Json?
  description   String
  payload       Json
  isProcessed   Boolean      @default(false)
  isCancelled   Boolean      @default(false)
  cancellationReason String?
  cascadesFrom  String?
  cascadeDepth  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  campaign      Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location      LocationNode? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([campaignId, triggerTime, isProcessed, isCancelled])
}

model TemporaryActor {
  id                  String       @id @default(cuid())
  campaignId          String
  label               String
  currentLocationId   String
  interactionCount    Int          @default(1)
  firstSeenAtTurn     Int
  lastSeenAtTurn      Int
  lastSeenAtTime      Int
  recentTopics        String[]     @default([])
  lastSummary         String?
  holdsInventory      Boolean      @default(false)
  affectedWorldState  Boolean      @default(false)
  isInMemoryGraph     Boolean      @default(false)
  promotedNpcId       String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  campaign            Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  currentLocation     LocationNode @relation(fields: [currentLocationId], references: [id], onDelete: Cascade)
  promotedNpc         NPC?         @relation(fields: [promotedNpcId], references: [id], onDelete: SetNull)

  @@index([campaignId, currentLocationId])
  @@index([campaignId, lastSeenAtTurn])
  @@unique([campaignId, currentLocationId, label])
}

model ScheduleGenerationJob {
  id            String   @id @default(cuid())
  campaignId    String
  queuedByTurnId String?
  dayNumber     Int
  dayStartTime  Int
  status        String   @default("pending")
  attempts      Int      @default(0)
  leaseOwnerId  String?
  leaseExpiresAt DateTime?
  lastError     String?
  infrastructureFailureCode String?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  queuedByTurn  Turn?    @relation(fields: [queuedByTurnId], references: [id], onDelete: SetNull)

  @@unique([campaignId, dayNumber])
  @@index([campaignId, status])
  @@index([status, leaseExpiresAt])
}

model MemoryEntityLink {
  id         String      @id @default(cuid())
  memoryId   String
  campaignId String
  entityType String
  entityId   String
  isPrimary  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  memory     MemoryEntry @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, entityType, entityId])
  @@index([memoryId])
}
